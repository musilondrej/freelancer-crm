#!/usr/bin/env bash

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

if [[ ! -x "vendor/bin/sail" ]]; then
    echo "[pre-commit] Missing vendor/bin/sail. Run composer install first."
    exit 1
fi

if ! git diff --quiet; then
    echo "[pre-commit] Unstaged changes detected."
    echo "[pre-commit] Stage or stash them first, then commit again."
    exit 1
fi

echo "[pre-commit] 1/3 Rector"
vendor/bin/sail composer lint:refactor

echo "[pre-commit] 2/3 Pint"
vendor/bin/sail composer lint:style

if ! git diff --quiet; then
    echo "[pre-commit] Rector/Pint updated files."
    echo "[pre-commit] Review changes, run git add, then commit again."
    git status --short
    exit 1
fi

echo "[pre-commit] 3/3 PHPStan"
vendor/bin/sail composer lint:static

echo "[pre-commit] OK"
